{
	"name": "risuko",
	"version": "0.1.3",
	"description": "A full-featured download manager",
	"homepage": "https://risuko.vercel.app",
	"author": {
		"name": "YueMiyuki",
		"email": "yuemiyuki4737@gmail.com"
	},
	"copyright": "Copyright© YueMiyuki",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git@github.com:YueMiyuki/Risuko.git"
	},
	"scripts": {
		"dev": "node scripts/dev.mjs",
		"build": "node scripts/build.mjs",
		"dev:renderer": "vite --config vite.renderer.config.ts --mode development --port 9080",
		"pack:renderer": "vite build --config vite.renderer.config.ts --mode production",
		"fmt": "pnpx @biomejs/biome check --write --max-diagnostics none",
		"typecheck": "vue-tsc --noEmit -p tsconfig.json",
		"knip": "pnpx knip --fix",
		"pre-commit": "pnpm typecheck && pnpm fmt",
		"prepare": "pnpx husky",
		"risuko": "node packages/risuko-cli/bin.js"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@tauri-apps/plugin-dialog": "^2.7.0",
		"@vueuse/core": "^14.2.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"eventemitter3": "^5.0.4",
		"lucide-vue-next": "^1.0.0",
		"reka-ui": "^2.9.6",
		"tailwind-merge": "^3.5.0",
		"tauri-plugin-nosleep-api": "^0.1.1",
		"tw-animate-css": "^1.4.0",
		"vaul-vue": "^0.4.1",
		"vee-validate": "^4.15.1",
		"vue-sonner": "^2.0.9"
	},
	"devDependencies": {
		"@bany/curl-to-json": "^1.2.10",
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/cli": "^2.10.1",
		"@types/node": "^25.6.0",
		"@vitejs/plugin-vue": "^6.0.6",
		"@vue/compiler-sfc": "^3.5.32",
		"axios": "^1.15.0",
		"cfonts": "^3.3.1",
		"chalk": "^5.6.2",
		"i18next": "^26.0.4",
		"lodash": "^4.18.1",
		"normalize.css": "^8.0.1",
		"pinia": "^3.0.4",
		"randomatic": "^3.1.1",
		"sass": "1.99.0",
		"tailwindcss": "^4.2.2",
		"terser": "^5.46.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.8",
		"vite-plugin-static-copy": "^4.0.1",
		"vue": "^3.5.32",
		"vue-router": "^5.0.4",
		"vue-tsc": "^3.2.6",
		"vue-virtual-scroller": "2.0.1"
	},
	"packageManager": "pnpm@10.32.1"
